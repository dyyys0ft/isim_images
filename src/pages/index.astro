<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ISIM - Instituto de la Salud Integral de la Mujer</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

:root{
    --navy:#0b1c2d;
    --navy-light:#132b45;
    --green-light:#4ade80;
    --green-glow:#22c55e;
    --glass: rgba(255,255,255,0.06);
    --text-soft:#cbd5e1;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins', sans-serif;
}

body{
    background: radial-gradient(circle at top left, #132b45, #0b1c2d 60%);
    color:white;
    min-height:100vh;
}

/* HEADER */
.header{
    height:80px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:0 60px;
    backdrop-filter: blur(12px);
    background: rgba(11,28,45,0.6);
    border-bottom:1px solid rgba(255,255,255,0.08);
}

.logo{
    font-size:26px;
    font-weight:700;
    letter-spacing:2px;
    color:var(--green-light);
}

.logo span{
    color:white;
    font-weight:400;
    font-size:14px;
    display:block;
    letter-spacing:1px;
}

.user-area{
    font-size:14px;
    color:var(--text-soft);
}

/* LAYOUT */
.layout{
    display:flex;
}

/* SIDEBAR */
.sidebar{
    width:270px;
    min-height:calc(100vh - 80px);
    background: linear-gradient(180deg, var(--navy-light), var(--navy));
    padding-top:40px;
    border-right:1px solid rgba(255,255,255,0.05);
}

.sidebar a{
    display:block;
    padding:16px 35px;
    color:var(--text-soft);
    text-decoration:none;
    font-size:15px;
    transition:0.4s;
    position:relative;
}

.sidebar a:hover{
    color:white;
    background:rgba(74,222,128,0.08);
}

.sidebar a:hover::before{
    content:"";
    position:absolute;
    left:0;
    top:0;
    height:100%;
    width:4px;
    background:var(--green-light);
    box-shadow:0 0 12px var(--green-glow);
}

/* MAIN */
.main{
    flex:1;
    padding:50px 60px;
}

/* HERO */
.hero{
    margin-bottom:50px;
}

.hero h1{
    font-size:34px;
    font-weight:600;
    margin-bottom:10px;
}

.hero p{
    color:var(--text-soft);
    font-size:15px;
}

/* DASHBOARD CARDS */
.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:30px;
}

.card{
    background:var(--glass);
    border:1px solid rgba(255,255,255,0.08);
    padding:35px;
    border-radius:20px;
    backdrop-filter:blur(14px);
    transition:0.4s;
}

.card:hover{
    transform:translateY(-8px);
    border-color:var(--green-light);
    box-shadow:0 0 30px rgba(34,197,94,0.2);
}

.card h3{
    font-size:18px;
    margin-bottom:15px;
}

.card p{
    font-size:14px;
    color:var(--text-soft);
    margin-bottom:20px;
}

.card button{
    background:linear-gradient(90deg,var(--green-light),var(--green-glow));
    border:none;
    padding:12px 22px;
    border-radius:40px;
    font-size:13px;
    font-weight:500;
    cursor:pointer;
    transition:0.4s;
}

.card button:hover{
    box-shadow:0 0 20px var(--green-glow);
}

/* METRICS STRIP */
.metrics{
    display:flex;
    gap:40px;
    margin-top:60px;
}

.metric-box{
    flex:1;
    background:rgba(255,255,255,0.05);
    padding:25px;
    border-radius:18px;
    text-align:center;
}

.metric-box h2{
    font-size:28px;
    color:var(--green-light);
}

.metric-box span{
    font-size:13px;
    color:var(--text-soft);
}

/* FOOTER */
.footer{
    margin-top:60px;
    text-align:center;
    font-size:12px;
    color:var(--text-soft);
    opacity:0.7;
}

</style>
</head>

<body>

<div class="header">
    <div class="logo">
        ISIM
        <span>Instituto de la Salud Integral de la Mujer</span>
    </div>
    <div class="user-area">
        Panel Ejecutivo • Acceso Seguro
    </div>
</div>

<div class="layout">

    <div class="sidebar">
        <a href="#">Panel General</a>
        <a href="#">Exámenes Clínicos</a>
        <a href="#">Pacientes</a>
        <a href="#">Resultados</a>
        <a href="#">Reportes Ejecutivos</a>
        <a href="#">Configuración</a>
    </div>

    <div class="main">

        <div class="hero">
            <h1>Centro Médico Premium Internacional</h1>
            <p>Gestión clínica avanzada con estándares hospitalarios de clase mundial.</p>
        </div>

        <div class="cards">
            <div class="card">
                <h3>Gestión de Exámenes</h3>
                <p>Administración y seguimiento clínico digital avanzado.</p>
                <button>Acceder</button>
            </div>

            <div class="card">
                <h3>Pacientes Activas</h3>
                <p>Historial clínico centralizado con seguridad médica.</p>
                <button>Ver Información</button>
            </div>

            <div class="card">
                <h3>Resultados Digitales</h3>
                <p>Entrega segura con generación de enlaces protegidos.</p>
                <button>Consultar</button>
            </div>

            <div class="card">
                <h3>Indicadores Clínicos</h3>
                <p>Estadísticas médicas y análisis institucional.</p>
                <button>Visualizar</button>
            </div>
        </div>

        <div class="metrics">
            <div class="metric-box">
                <h2>1,248</h2>
                <span>Exámenes Procesados</span>
            </div>
            <div class="metric-box">
                <h2>312</h2>
                <span>Pacientes Registradas</span>
            </div>
            <div class="metric-box">
                <h2>98%</h2>
                <span>Satisfacción Clínica</span>
            </div>
        </div>

        <div class="footer">
            © 2026 ISIM • Instituto de la Salud Integral de la Mujer • Plataforma Médica Internacional
        </div>

    </div>
</div>

</body>
</html>